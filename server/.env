# Porta do servidor Express
PORT=3005

# PostgreSQL — ajuste para sua instalação local
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dashboard

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=dev_secret_troque_em_producao_use_64_chars_aleatorios

# Senha de acesso ao painel
ADMIN_PASSWORD=110agencia

# Procfy — sistema financeiro
# Gere a API Key em: app.procfy.io → Configurações → Integrações → API
PROCFY_API_KEY=
PROCFY_BASE_URL=https://api.procfy.io
